# 前端构建时需要的环境变量
# 在 Vercel Dashboard → Project Settings → Environment Variables 中设置
#
# VITE_API_BASE = Render 后端部署后的 URL
# VITE_WS_BASE  = Render 后端的 WebSocket URL（把 https 换成 wss）
#
# 示例（部署后替换成实际 Render URL）：
# VITE_API_BASE=https://industry-audit-backend.onrender.com
# VITE_WS_BASE=wss://industry-audit-backend.onrender.com

VITE_API_BASE=
VITE_WS_BASE=
