# ═══════════════════════════════════════════════════════════
#  IndustryAgent 生产环境配置
#  在 Render Dashboard → Environment 中逐项设置
#  不要提交真实值到 Git！
# ═══════════════════════════════════════════════════════════

# ── Web 安全 ─────────────────────────────────────────────
# SECRET_KEY 必须 ≥32 字符，用以下命令生成：
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# CORS_ORIGINS = Vercel 前端域名，多个用逗号分隔
CORS_ORIGINS=https://your-frontend.vercel.app

COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# ── 数据库 ───────────────────────────────────────────────
# SQLite 文件存储在容器内，重启会丢失！生产建议用 PostgreSQL
# Render 可以附加 PostgreSQL 数据库
DATABASE_URL=sqlite:///./data/audit.db
ENGINE_DB_PATH=./data/audit.db

# ── 文件上传 ─────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=50

# ── 全局开关 ─────────────────────────────────────────────
LLM_USE_MOCK=false

# ═══════════════════════════════════════════════════════════
#  以下为 LLM API 配置，从你的 API 提供商获取
# ═══════════════════════════════════════════════════════════

# ── 场景一 Explorer A（DeepSeek）─────────────────────────
S1_EXPLORER_A_BASE_URL=
S1_EXPLORER_A_API_KEY=
S1_EXPLORER_A_MODEL=deepseek-chat

# ── 场景一 Explorer B（Qwen）─────────────────────────────
S1_EXPLORER_B_BASE_URL=
S1_EXPLORER_B_API_KEY=
S1_EXPLORER_B_MODEL=qwen-plus

# ── 场景二 Explorer A（Qwen）─────────────────────────────
S2_EXPLORER_A_BASE_URL=
S2_EXPLORER_A_API_KEY=
S2_EXPLORER_A_MODEL=qwen-plus

# ── 场景二 Explorer B（Gemini，支持视觉）─────────────────
S2_EXPLORER_B_BASE_URL=
S2_EXPLORER_B_API_KEY=
S2_EXPLORER_B_MODEL=gemini-1.5-flash

# ── 场景一 Critic（DeepSeek Reasoner）────────────────────
S1_CRITIC_BASE_URL=
S1_CRITIC_API_KEY=
S1_CRITIC_MODEL=deepseek-reasoner

# ── 场景二 Critic────────────────────────────────────────
S2_CRITIC_BASE_URL=
S2_CRITIC_API_KEY=
S2_CRITIC_MODEL=deepseek-reasoner

# ── Monitor Agent─────────────────────────────────────────
MONITOR_BASE_URL=
MONITOR_API_KEY=
MONITOR_MODEL=deepseek-chat
MONITOR_INTERVAL_SEC=20
