# ── 必填：生产环境必须修改 ─────────────────────────────────────────────────
# 长度至少 32 字符，生产下必须是随机值（python -c "import secrets; print(secrets.token_urlsafe(48))"）
SECRET_KEY=CHANGE_ME_USE_python_secrets_token_urlsafe_48

# ── 数据库 ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:////opt/industryagent/data/audit.db
ENGINE_DB_PATH=/opt/industryagent/data/audit.db

# ── CORS：生产下只写你的域名，不允许 * ──────────────────────────────────────
CORS_ORIGINS=https://YOUR_DOMAIN

# ── 文件上传 ───────────────────────────────────────────────────────────────
UPLOAD_DIR=/opt/industryagent/data/uploads
MAX_UPLOAD_MB=50

# ── Cookie 安全策略 ────────────────────────────────────────────────────────
COOKIE_SECURE=true          # 生产必须 true（HTTPS）
COOKIE_SAMESITE=lax         # lax | strict | none
COOKIE_HTTPONLY=true

# ── LLM 后端 ──────────────────────────────────────────────────────────────
LLM_BASE_URL=http://localhost:8000/v1
LLM_TEXT_MODEL=Qwen3-1.7B-Instruct
LLM_USE_MOCK=false          # 生产改为 false，连接真实 vLLM
